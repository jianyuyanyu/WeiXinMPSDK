/* ratio=1:1 | 色源：pages/websocket/websocket.wxss .messageContext { color:teal } + Login .auth-btn #07b84a
 *      暗黑：底 #1a2e22，消息色 #4db88a
 */
.card {
  padding: 3.2vw;
  border-radius: 1.07vw;
  background: #ffffff;
  border: 1px solid rgba(7, 184, 74, 0.2);
}

@media (prefers-color-scheme: dark) {
  .card {
    background: #1a2e22;
    border-color: rgba(7, 184, 74, 0.35);
  }
}

.card-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2.13vw;
}

.card-title {
  font-size: 4.53vw;
  color: rgba(0, 0, 0, 0.9);
  font-weight: 600;
}

.card-subtitle {
  font-size: 3.2vw;
  color: rgba(0, 0, 0, 0.45);
}

@media (prefers-color-scheme: dark) {
  .card-title {
    color: rgba(255, 255, 255, 0.9);
  }
  .card-subtitle {
    color: rgba(255, 255, 255, 0.45);
  }
}

.card-body {
  margin-bottom: 3.2vw;
}

.empty-tip {
  padding: 4.27vw 0;
}

.empty-text {
  font-size: 4vw;
  color: rgba(0, 0, 0, 0.45);
}

@media (prefers-color-scheme: dark) {
  .empty-text {
    color: rgba(255, 255, 255, 0.45);
  }
}

.message-item {
  padding: 2.13vw 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}

@media (prefers-color-scheme: dark) {
  .message-item {
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }
}

.message-time {
  display: block;
  font-size: 3.2vw;
  color: rgba(0, 0, 0, 0.3);
  margin-bottom: 0.53vw;
}

.message-content {
  display: block;
  font-size: 4vw;
  color: #008080;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

@media (prefers-color-scheme: dark) {
  .message-time {
    color: rgba(255, 255, 255, 0.3);
  }
  .message-content {
    color: #4db88a;
  }
}

.more-tip {
  padding: 2.13vw 0;
}

.more-tip-hover {
  opacity: 0.7;
}

.more-text {
  font-size: 3.2vw;
  color: #07b84a;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  padding: 2.13vw 4.27vw;
  border-radius: 1.07vw;
  background: #07b84a;
}

.action-btn-hover {
  opacity: 0.85;
}

.action-btn-text {
  font-size: 4vw;
  color: #ffffff;
}
