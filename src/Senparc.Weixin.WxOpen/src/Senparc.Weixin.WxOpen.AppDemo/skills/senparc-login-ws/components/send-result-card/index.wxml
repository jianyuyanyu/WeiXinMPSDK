<view class="card">
  <view class="card-header">
    <text class="card-title">发送结果</text>
  </view>
  <view class="card-body">
    <text class="status-icon">{{sent ? '✓' : '·'}}</text>
    <text class="status-text">{{statusText}}</text>
    <text class="message-text" wx:if="{{message}}">「{{message}}」</text>
  </view>
  <view class="card-actions">
    <view class="action-btn primary" hover-class="action-btn-hover" bindtap="onTapMessages">
      <text class="action-btn-text">查看消息</text>
    </view>
  </view>
</view>
